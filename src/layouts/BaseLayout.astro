---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "CodeArmy is a repo-first orchestration layer for long-running AI coding and research projects."
} = Astro.props;

const pageTitle = `${title} | CodeArmy`;

// Determine current locale from URL path
const currentPath = Astro.url.pathname;
const isZhPath = currentPath.startsWith("/zh/") || currentPath === "/zh";
const currentLocale = isZhPath ? "zh" : "en";

// Get counterpart path for language switching
function getCounterpartPath(path: string): string {
  const mappings: Record<string, string> = {
    "/": "/zh/",
    "/how-it-works/": "/zh/how-it-works/",
    "/research-use-cases/": "/zh/research-use-cases/",
    "/integrations/": "/zh/integrations/",
    "/roadmap/": "/zh/roadmap/",
    "/docs/": "/zh/docs/",
    "/docs/quickstart/": "/zh/docs/quickstart/",
  };
  
  // Check exact match
  if (mappings[path]) {
    return mappings[path];
  }
  
  // Check reverse mappings
  const reverseMappings: Record<string, string> = Object.fromEntries(
    Object.entries(mappings).map(([en, zh]) => [zh, en])
  );
  if (reverseMappings[path]) {
    return reverseMappings[path];
  }
  
  // Handle generic /zh/* paths
  if (path.startsWith("/zh/")) {
    const enPath = "/" + path.slice(4);
    return enPath.endsWith("/") ? enPath : enPath + "/";
  }
  
  // Add /zh/ prefix for English paths
  const zhPath = "/zh" + path;
  return zhPath.endsWith("/") ? zhPath : zhPath + "/";
}

const counterpartPath = getCounterpartPath(currentPath);
const switchLabel = currentLocale === "zh" ? "English" : "中文";
---

<!doctype html>
<html lang={currentLocale === "zh" ? "zh-CN" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
    <link rel="canonical" href={Astro.url.href} />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href={`${import.meta.env.BASE_URL}`}>
          <span class="brand-mark">CA</span>
          <span class="brand-text">
            <strong>CodeArmy</strong>
            <small>Powered by Alice Runtime</small>
          </span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href={`${import.meta.env.BASE_URL}`}>Home</a>
          <a href={`${import.meta.env.BASE_URL}how-it-works/`}>How It Works</a>
          <a href={`${import.meta.env.BASE_URL}research-use-cases/`}>Research</a>
          <a href={`${import.meta.env.BASE_URL}integrations/`}>Integrations</a>
          <a href={`${import.meta.env.BASE_URL}roadmap/`}>Roadmap</a>
          <a href={`${import.meta.env.BASE_URL}docs/quickstart/`}>Quickstart</a>
        </nav>
        <div class="lang-switcher">
          <button 
            class="lang-switcher-btn" 
            data-counterpart={counterpartPath}
            aria-label={`Switch to ${switchLabel}`}
          >
            <span class="lang-current">{currentLocale === "zh" ? "中" : "EN"}</span>
            <span class="lang-separator">/</span>
            <span class="lang-target">{switchLabel}</span>
          </button>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <p class="eyebrow">CodeArmy</p>
          <p class="footer-copy">
            A repo-first orchestration layer for long-horizon coding and research campaigns.
          </p>
        </div>
        <div>
          <p class="footer-title">Explore</p>
          <ul class="footer-links">
            <li><a href={`${import.meta.env.BASE_URL}docs/quickstart/`}>Quickstart</a></li>
            <li><a href={`${import.meta.env.BASE_URL}how-it-works/`}>How It Works</a></li>
            <li><a href={`${import.meta.env.BASE_URL}research-use-cases/`}>Research Use Cases</a></li>
          </ul>
        </div>
        <div>
          <p class="footer-title">Current Code</p>
          <ul class="footer-links">
            <li><a href="https://github.com/Alice-space/alice">Alice Runtime Repo</a></li>
            <li><a href="https://github.com/Alice-space/codearmy-site">Site Repo</a></li>
          </ul>
        </div>
      </div>
    </footer>

    <script>
      import { initLocale, switchLanguage, storeLocale, getLocaleFromPath } from "../lib/i18n";
      
      // Initialize locale on page load
      initLocale();
      
      // Set up language switcher
      document.addEventListener("DOMContentLoaded", () => {
        const langBtn = document.querySelector(".lang-switcher-btn") as HTMLButtonElement | null;
        
        if (langBtn) {
          langBtn.addEventListener("click", () => {
            const counterpartPath = langBtn.dataset.counterpart;
            const currentPath = window.location.pathname;
            
            // Determine new locale from target path
            const isZhTarget = counterpartPath?.startsWith("/zh/") || counterpartPath === "/zh";
            const newLocale = isZhTarget ? "zh" : "en";
            
            // Store preference
            storeLocale(newLocale);
            
            // Navigate
            if (counterpartPath && counterpartPath !== currentPath) {
              window.location.href = counterpartPath;
            }
          });
        }
      });
    </script>
  </body>
</html>
