---
import "../styles/global.css";
import { getCounterpartPath, isZhPath } from "../lib/i18n";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "CodeArmy is a repo-first orchestration layer for long-running AI coding and research projects."
} = Astro.props;

const pageTitle = `${title} | CodeArmy`;

// Normalize BASE_URL to ensure it ends with a trailing slash
const baseUrl = import.meta.env.BASE_URL.endsWith('/') 
  ? import.meta.env.BASE_URL 
  : `${import.meta.env.BASE_URL}/`;

// Determine current locale from URL path
const currentPath = Astro.url.pathname;
const currentLocale = isZhPath(currentPath) ? "zh" : "en";

// Get counterpart path for language switching (reuse shared mapping)
const counterpartPath = getCounterpartPath(currentPath);
const switchLabel = currentLocale === "zh" ? "English" : "中文";

const navItems = [
  { href: `${baseUrl}`, label: "Home" },
  { href: `${baseUrl}how-it-works/`, label: "How It Works" },
  { href: `${baseUrl}research-use-cases/`, label: "Research" },
  { href: `${baseUrl}integrations/`, label: "Integrations" },
  { href: `${baseUrl}roadmap/`, label: "Roadmap" },
  { href: `${baseUrl}docs/quickstart/`, label: "Quickstart", highlight: true },
];

const footerLinks = {
  explore: [
    { href: `${baseUrl}docs/quickstart/`, label: "Quickstart" },
    { href: `${baseUrl}how-it-works/`, label: "How It Works" },
    { href: `${baseUrl}research-use-cases/`, label: "Research Use Cases" },
  ],
  code: [
    { href: "https://github.com/Alice-space/alice", label: "Alice Runtime Repo" },
    { href: "https://github.com/Alice-space/codearmy-site", label: "Site Repo" },
  ],
};
---

<!doctype html>
<html lang={currentLocale === "zh" ? "zh-CN" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href={`${baseUrl}favicon.svg`} type="image/svg+xml" />
    <link rel="canonical" href={Astro.url.href} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href={`${baseUrl}`} aria-label="CodeArmy Home">
          <span class="brand-mark" aria-hidden="true">CA</span>
          <span class="brand-text">
            <strong>CodeArmy</strong>
            <small>Repo-First Orchestration</small>
          </span>
        </a>
        
        <button 
          class="nav-toggle" 
          aria-label="Toggle navigation" 
          aria-expanded="false"
          aria-controls="site-nav"
        >
          <span class="nav-toggle-bar" aria-hidden="true"></span>
          <span class="nav-toggle-bar" aria-hidden="true"></span>
          <span class="nav-toggle-bar" aria-hidden="true"></span>
        </button>
        
        <nav class="site-nav" id="site-nav" aria-label="Primary">
          {navItems.map(item => (
            <a 
              href={item.href} 
              class={item.highlight ? "nav-highlight" : ""}
              aria-current={Astro.url.pathname === item.href || (Astro.url.pathname === baseUrl && item.href === baseUrl) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <div class="lang-switcher">
          <button 
            class="lang-switcher-btn" 
            data-counterpart={counterpartPath}
            aria-label={`Switch to ${switchLabel}`}
          >
            <span class="lang-current">{currentLocale === "zh" ? "中" : "EN"}</span>
            <span class="lang-separator">/</span>
            <span class="lang-target">{switchLabel}</span>
          </button>
        </div>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div class="footer-brand">
          <p class="eyebrow">CodeArmy</p>
          <p class="footer-copy">
            A repo-first orchestration layer for long-horizon coding and research campaigns.
          </p>
        </div>
        <div class="footer-section">
          <p class="footer-title">Explore</p>
          <ul class="footer-links">
            {footerLinks.explore.map(link => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="footer-section">
          <p class="footer-title">Current Code</p>
          <ul class="footer-links">
            {footerLinks.code.map(link => (
              <li><a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
      <div class="container footer-meta">
        <p>Built for long-horizon AI coding and research workflows.</p>
      </div>
    </footer>

    <script>
      import { initLocale, storeLocale, isZhPath, isZhPathAvailable, getLocaleFromPath } from "../lib/i18n";

      // Initialize locale on page load
      initLocale();

      // Set up language switcher
      document.addEventListener("DOMContentLoaded", () => {
        const langBtn = document.querySelector(".lang-switcher-btn") as HTMLButtonElement | null;

        if (langBtn) {
          langBtn.addEventListener("click", () => {
            const counterpartPath = langBtn.dataset.counterpart;
            const currentPath = window.location.pathname;
            
            if (!counterpartPath) return;

            const currentLocale = getLocaleFromPath(currentPath);
            const newLocale = currentLocale === "zh" ? "en" : "zh";
            
            // ALWAYS store user preference first (even if target page doesn't exist)
            storeLocale(newLocale);
            console.log(`[i18n] Preference saved: ${newLocale}`);

            // Check if switching to Chinese and the page exists
            const switchingToZh = isZhPath(counterpartPath);
            if (switchingToZh && !isZhPathAvailable(counterpartPath)) {
              // Chinese page not available yet - preference is saved but stay on current page
              console.log("[i18n] Chinese page not yet available, staying on current page. Will redirect when T402/T403 creates the page.");
              // Could add UI notification here in the future
              return;
            }

            // Navigate to counterpart path
            window.location.href = counterpartPath;
          });
        }
      });

      // Mobile navigation toggle
      const navToggle = document.querySelector('.nav-toggle');
      const siteNav = document.getElementById('site-nav');
      
      if (navToggle && siteNav) {
        navToggle.addEventListener('click', () => {
          const isExpanded = navToggle.getAttribute('aria-expanded') === 'true';
          navToggle.setAttribute('aria-expanded', String(!isExpanded));
          siteNav.classList.toggle('is-open');
        });
        
        // Close nav when clicking on a link
        siteNav.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            navToggle.setAttribute('aria-expanded', 'false');
            siteNav.classList.remove('is-open');
          });
        });
      }
    </script>
  </body>
</html>
