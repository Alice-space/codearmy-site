---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "CodeArmy is a repo-first orchestration layer for long-running AI coding and research projects."
} = Astro.props;

const pageTitle = `${title} | CodeArmy`;
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const currentPath = Astro.url.pathname;

const stripBase = (path: string) => {
  if (baseUrl !== "/" && path.startsWith(baseUrl.slice(0, -1))) {
    return path.slice(baseUrl.length - 1) || "/";
  }
  return path || "/";
};

const addBase = (path: string) => {
  if (baseUrl === "/") return path;
  return `${baseUrl.replace(/\/$/, "")}${path}`;
};

const normalizePath = (path: string) => {
  if (path === "/zh") return "/zh/";
  if (path !== "/" && !path.endsWith("/")) return `${path}/`;
  return path;
};

const routeSectionMap: Record<string, string> = {
  "/": "#hero",
  "/how-it-works/": "#workflow",
  "/research-use-cases/": "#cases",
  "/integrations/": "#entry",
  "/roadmap/": "#roadmap",
  "/docs/": "#docs",
  "/docs/quickstart/": "#docs",
  "/zh/": "#hero",
  "/zh/how-it-works/": "#workflow",
  "/zh/research-use-cases/": "#cases",
  "/zh/integrations/": "#entry",
  "/zh/roadmap/": "#roadmap",
  "/zh/docs/": "#docs",
  "/zh/docs/quickstart/": "#docs"
};

const strippedPath = normalizePath(stripBase(currentPath));
const currentLocale = strippedPath.startsWith("/zh/") ? "zh" : "en";
const sectionAnchor = routeSectionMap[strippedPath] ?? "#hero";

const localeRoot = currentLocale === "zh" ? addBase("/zh/") : addBase("/");
const counterpartRoot = currentLocale === "zh" ? addBase("/") : addBase("/zh/");
const counterpartHref = `${counterpartRoot}${sectionAnchor}`;
const activeAnchor = sectionAnchor.replace("#", "");

const labels =
  currentLocale === "zh"
    ? {
        home: "总览",
        workflow: "工作原理",
        cases: "研究场景",
        entry: "接入面",
        roadmap: "路线图",
        quickstart: "快速入门",
        switchTarget: "English",
        switchAria: "切换到英文",
        currentBadge: "中",
        footerExplore: "探索",
        footerCode: "当前代码",
        footerCopy: "面向长期 AI 编码与研究 campaign 的 repo-first orchestration layer。",
        brandSubline: "Repo-first Orchestration",
        skipLink: "跳到主要内容",
        menuLabel: "主导航",
        menuToggle: "切换导航"
      }
    : {
        home: "Overview",
        workflow: "Workflow",
        cases: "Use Cases",
        entry: "Entry Surfaces",
        roadmap: "Roadmap",
        quickstart: "Quickstart",
        switchTarget: "中文",
        switchAria: "Switch to Chinese",
        currentBadge: "EN",
        footerExplore: "Explore",
        footerCode: "Current Code",
        footerCopy: "A repo-first orchestration layer for long-horizon coding and research campaigns.",
        brandSubline: "Repo-first Orchestration",
        skipLink: "Skip to main content",
        menuLabel: "Primary",
        menuToggle: "Toggle navigation"
      };

const navItems =
  currentLocale === "zh"
    ? [
        { href: `${localeRoot}#hero`, label: labels.home, anchor: "hero" },
        { href: `${localeRoot}#workflow`, label: labels.workflow, anchor: "workflow" },
        { href: `${localeRoot}#cases`, label: labels.cases, anchor: "cases" },
        { href: `${localeRoot}#entry`, label: labels.entry, anchor: "entry" },
        { href: `${localeRoot}#roadmap`, label: labels.roadmap, anchor: "roadmap" },
        { href: `${localeRoot}#docs`, label: labels.quickstart, anchor: "docs" }
      ]
    : [
        { href: `${localeRoot}#hero`, label: labels.home, anchor: "hero" },
        { href: `${localeRoot}#workflow`, label: labels.workflow, anchor: "workflow" },
        { href: `${localeRoot}#cases`, label: labels.cases, anchor: "cases" },
        { href: `${localeRoot}#entry`, label: labels.entry, anchor: "entry" },
        { href: `${localeRoot}#roadmap`, label: labels.roadmap, anchor: "roadmap" },
        { href: `${localeRoot}#docs`, label: labels.quickstart, anchor: "docs" }
      ];

const footerLinks =
  currentLocale === "zh"
    ? [
        { href: `${localeRoot}#docs`, label: "快速入门" },
        { href: `${localeRoot}#workflow`, label: "工作原理" },
        { href: `${localeRoot}#cases`, label: "研究场景" }
      ]
    : [
        { href: `${localeRoot}#docs`, label: "Quickstart" },
        { href: `${localeRoot}#workflow`, label: "Workflow" },
        { href: `${localeRoot}#cases`, label: "Research" }
      ];
---

<!doctype html>
<html lang={currentLocale === "zh" ? "zh-CN" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href={`${baseUrl}favicon.svg`} type="image/svg+xml" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" hreflang={currentLocale === "zh" ? "zh-CN" : "en"} href={Astro.url.href} />
    <link
      rel="alternate"
      hreflang={currentLocale === "zh" ? "en" : "zh-CN"}
      href={new URL(counterpartHref, Astro.site)}
    />
    <link rel="alternate" hreflang="x-default" href={new URL(baseUrl, Astro.site)} />
  </head>
<body>
    <a href="#main-content" class="skip-link">{labels.skipLink}</a>

    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href={localeRoot} aria-label="CodeArmy Home">
          <span class="brand-mark" aria-hidden="true">CA</span>
          <span class="brand-text">
            <strong>CodeArmy</strong>
            <small>{labels.brandSubline}</small>
          </span>
        </a>

        <button
          type="button"
          class="nav-toggle"
          aria-label={labels.menuToggle}
          aria-expanded="false"
          aria-controls="site-nav"
        >
          <span class="nav-toggle-bar" aria-hidden="true"></span>
          <span class="nav-toggle-bar" aria-hidden="true"></span>
          <span class="nav-toggle-bar" aria-hidden="true"></span>
        </button>

        <nav class="site-nav" id="site-nav" aria-label={labels.menuLabel}>
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "nav-link",
                item.anchor === activeAnchor ? "is-active" : "",
                item.anchor === "docs" ? "nav-highlight" : ""
              ]}
              aria-current={item.anchor === activeAnchor ? "page" : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>

        <div class="lang-switcher">
            <button
              type="button"
              class="lang-switcher-btn"
              data-current-locale={currentLocale}
              data-counterpart-root={counterpartRoot}
              data-section-anchor={sectionAnchor}
              data-counterpart={counterpartHref}
              data-next-locale={currentLocale === "zh" ? "en" : "zh"}
              aria-label={labels.switchAria}
          >
            <span class="lang-current">{labels.currentBadge}</span>
            <span class="lang-separator">/</span>
            <span class="lang-target">{labels.switchTarget}</span>
          </button>
        </div>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div class="footer-brand">
          <p class="eyebrow">CodeArmy</p>
          <p class="footer-copy">{labels.footerCopy}</p>
        </div>
        <div class="footer-section">
          <p class="footer-title">{labels.footerExplore}</p>
          <ul class="footer-links">
            {footerLinks.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="footer-section">
          <p class="footer-title">{labels.footerCode}</p>
          <ul class="footer-links">
            <li><a href="https://github.com/Alice-space/alice">Alice Runtime Repo</a></li>
            <li><a href="https://github.com/Alice-space/codearmy-site">Site Repo</a></li>
          </ul>
        </div>
      </div>
      <div class="container footer-meta">
        <p>{labels.footerCopy}</p>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const STORAGE_KEY = "codearmy-locale-pref";

        const storeLocale = (locale: string) => {
          try {
            window.localStorage.setItem(STORAGE_KEY, locale);
          } catch (_err) {
            // ignore localStorage exceptions in restricted environments
          }
        };

        document.addEventListener("DOMContentLoaded", () => {
          const normalizeSectionHash = (hash) => {
            const valid = new Set(["#hero", "#workflow", "#cases", "#entry", "#roadmap", "#docs"]);
            return valid.has(hash) ? hash : "#hero";
          };

          const langButton = document.querySelector(".lang-switcher-btn");
          if (langButton instanceof HTMLButtonElement) {
            langButton.addEventListener("click", () => {
              const nextLocale = langButton.dataset.nextLocale;
              const fallbackAnchor = langButton.dataset.sectionAnchor || "#hero";
              const hash = normalizeSectionHash(window.location.hash || fallbackAnchor);
              const targetRoot = langButton.dataset.counterpartRoot || "";
              const target = `${targetRoot}${hash}`;
              if (nextLocale) {
                storeLocale(nextLocale);
              }
              if (target) {
                window.location.href = target;
              }
            });
          }

          const navToggle = document.querySelector(".nav-toggle");
          const siteNav = document.getElementById("site-nav");
          if (navToggle instanceof HTMLButtonElement && siteNav) {
            navToggle.addEventListener("click", () => {
              const expanded = navToggle.getAttribute("aria-expanded") === "true";
              navToggle.setAttribute("aria-expanded", String(!expanded));
              siteNav.classList.toggle("is-open");
            });

            siteNav.querySelectorAll("a").forEach((link) => {
              link.addEventListener("click", () => {
                navToggle.setAttribute("aria-expanded", "false");
                siteNav.classList.remove("is-open");
              });
            });
          }

          const updateActive = () => {
            const hash = window.location.hash || "#hero";
            document.querySelectorAll(".site-nav a").forEach((link) => {
              const href = link.getAttribute("href") || "";
              const active = href.endsWith(hash);
              link.classList.toggle("is-active", active);
              if (active) {
                link.setAttribute("aria-current", "page");
              } else {
                link.removeAttribute("aria-current");
              }
            });
          };

          updateActive();
          window.addEventListener("hashchange", updateActive);
        });
      })();
    </script>
  </body>
</html>
