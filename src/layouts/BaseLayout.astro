---
import "../styles/global.css";

type Locale = "en" | "zh";

interface NavItem {
  id: string;
  label: string;
}

interface Props {
  locale: Locale;
  title: string;
  description?: string;
  navItems: NavItem[];
  footerNote: string;
}

const {
  locale,
  title,
  description = "CodeArmy is a repo-first orchestration layer for long-horizon AI coding and research campaigns.",
  navItems,
  footerNote
} = Astro.props;

const pageTitle = `${title} | CodeArmy`;
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const addBase = (path: string) => {
  if (baseUrl === "/") return path;
  return `${baseUrl.replace(/\/$/, "")}${path}`;
};

const localeRoot = locale === "zh" ? addBase("/zh/") : addBase("/");
const counterpartRoot = locale === "zh" ? addBase("/") : addBase("/zh/");
const currentUrl = Astro.url.href;
const counterpartUrl = new URL(counterpartRoot, Astro.site);

const ui =
  locale === "zh"
    ? {
        htmlLang: "zh-CN",
        skipLink: "跳到主要内容",
        navLabel: "主导航",
        menuToggle: "切换导航",
        switchLabel: "EN",
        switchAria: "切换到英文",
        brandSubline: "Repo-First Campaign Orchestration",
        footerExplore: "导航",
        footerRepos: "仓库"
      }
    : {
        htmlLang: "en",
        skipLink: "Skip to main content",
        navLabel: "Primary navigation",
        menuToggle: "Toggle navigation",
        switchLabel: "中文",
        switchAria: "Switch to Chinese",
        brandSubline: "Repo-First Campaign Orchestration",
        footerExplore: "Explore",
        footerRepos: "Repositories"
      };
---

<!doctype html>
<html lang={ui.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href={`${baseUrl}favicon.svg`} type="image/svg+xml" />
    <link rel="canonical" href={currentUrl} />
    <link rel="alternate" hreflang={locale === "zh" ? "zh-CN" : "en"} href={currentUrl} />
    <link rel="alternate" hreflang={locale === "zh" ? "en" : "zh-CN"} href={counterpartUrl} />
    <link rel="alternate" hreflang="x-default" href={new URL(addBase("/"), Astro.site)} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">{ui.skipLink}</a>

    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href={localeRoot} aria-label="CodeArmy">
          <span class="brand-mark" aria-hidden="true">CA</span>
          <span class="brand-copy">
            <strong>CodeArmy</strong>
            <small>{ui.brandSubline}</small>
          </span>
        </a>

        <button
          type="button"
          class="nav-toggle"
          aria-label={ui.menuToggle}
          aria-controls="site-nav"
          aria-expanded="false"
        >
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
        </button>

        <nav id="site-nav" class="site-nav" aria-label={ui.navLabel}>
          {navItems.map((item) => (
            <a class="nav-link" href={`${localeRoot}#${item.id}`} data-section={item.id}>
              {item.label}
            </a>
          ))}
        </nav>

        <a
          class="lang-switcher-btn"
          href={counterpartRoot}
          data-target-root={counterpartRoot}
          aria-label={ui.switchAria}
        >
          {ui.switchLabel}
        </a>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <p class="eyebrow">CodeArmy</p>
          <p class="footer-copy">{footerNote}</p>
        </div>
        <div>
          <p class="footer-title">{ui.footerExplore}</p>
          <ul class="footer-links">
            {navItems.map((item) => (
              <li><a href={`${localeRoot}#${item.id}`}>{item.label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <p class="footer-title">{ui.footerRepos}</p>
          <ul class="footer-links">
            <li><a href="https://github.com/Alice-space/alice">Alice Runtime</a></li>
            <li><a href="https://github.com/Alice-space/codearmy-site">CodeArmy Site</a></li>
          </ul>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const navLinks = Array.from(document.querySelectorAll(".nav-link[data-section]"));
        const langButton = document.querySelector(".lang-switcher-btn");
        const navToggle = document.querySelector(".nav-toggle");
        const siteNav = document.getElementById("site-nav");

        const validSectionIds = new Set(
          navLinks
            .map((link) => link.getAttribute("data-section"))
            .filter((value) => typeof value === "string" && value.length > 0)
        );

        const setActive = (id) => {
          navLinks.forEach((link) => {
            const current = link.getAttribute("data-section") === id;
            link.classList.toggle("is-active", current);
            if (current) {
              link.setAttribute("aria-current", "page");
            } else {
              link.removeAttribute("aria-current");
            }
          });
        };

        const updateLangHref = () => {
          if (!(langButton instanceof HTMLAnchorElement)) return;
          const root = langButton.dataset.targetRoot || "/";
          const rawHash = window.location.hash || "";
          const hashId = rawHash.replace(/^#/, "");
          const safeHash = validSectionIds.has(hashId) ? `#${hashId}` : "";
          langButton.href = `${root}${safeHash}`;
        };

        const syncByHash = () => {
          const hashId = window.location.hash.replace(/^#/, "");
          if (validSectionIds.has(hashId)) {
            setActive(hashId);
          } else if (validSectionIds.has("overview")) {
            setActive("overview");
          }
          updateLangHref();
        };

        const sections = navLinks
          .map((link) => document.getElementById(link.getAttribute("data-section") || ""))
          .filter((section) => section instanceof HTMLElement);

        if (sections.length > 0) {
          const observer = new IntersectionObserver(
            (entries) => {
              const visible = entries
                .filter((entry) => entry.isIntersecting)
                .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

              if (visible?.target instanceof HTMLElement) {
                const id = visible.target.id;
                if (validSectionIds.has(id)) {
                  setActive(id);
                }
              }
            },
            {
              rootMargin: "-35% 0px -45% 0px",
              threshold: [0.2, 0.45, 0.7]
            }
          );

          sections.forEach((section) => observer.observe(section));
        }

        if (navToggle instanceof HTMLButtonElement && siteNav instanceof HTMLElement) {
          navToggle.addEventListener("click", () => {
            const expanded = navToggle.getAttribute("aria-expanded") === "true";
            navToggle.setAttribute("aria-expanded", String(!expanded));
            siteNav.classList.toggle("is-open");
          });

          navLinks.forEach((link) => {
            link.addEventListener("click", () => {
              navToggle.setAttribute("aria-expanded", "false");
              siteNav.classList.remove("is-open");
            });
          });
        }

        syncByHash();
        window.addEventListener("hashchange", syncByHash);
      })();
    </script>
  </body>
</html>
