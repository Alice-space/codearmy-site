---
import BaseLayout from "../layouts/BaseLayout.astro";

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const pillars = [
  {
    title: "Repo-First Campaigns",
    text: "Track long-horizon work in a structured campaign, not a disposable chat thread."
  },
  {
    title: "Hard Workflow Gates",
    text: "Plan, review, approve, execute, reconcile, and report with explicit transitions."
  },
  {
    title: "Research-Ready",
    text: "Designed for code, experiments, cluster runs, metrics, and evidence to move together."
  }
];

const workflow = [
  "Create a campaign with a clear objective, baseline, and gates.",
  "Generate task packages that give each role a bounded, auditable unit of work.",
  "Run planner, reviewer, and executor loops with explicit handoff states.",
  "Reconcile the repo to refresh live status, select next actions, and surface blockers.",
  "Publish progress and closure reports without losing the evidence trail."
];

const integrations = ["Trae Solo", "CLI", "Feishu", "Cluster / HPC", "Reports", "Repo Templates"];

const entryPoints = [
  {
    title: "Trae Solo",
    text: "Use CodeArmy as the orchestration layer behind custom agents, MCP tools, and Skills."
  },
  {
    title: "CLI and Automation",
    text: "Create campaigns, reconcile state, and generate reports from scripts and scheduled jobs."
  },
  {
    title: "Feishu and Team Sync",
    text: "Push summaries, approvals, and report artifacts back into team collaboration channels."
  },
  {
    title: "Cluster Workflows",
    text: "Connect experiments, training runs, and evaluation jobs to the same campaign timeline."
  }
];
---

<BaseLayout
  title="Repo-First Orchestration for Long-Horizon AI Coding"
  description="CodeArmy turns long-running coding and research efforts into structured campaigns with planning, review, reconcile, and reporting."
>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">CodeArmy</p>
        <h1>Turn long-horizon AI coding into structured campaigns.</h1>
        <p class="lead">
          CodeArmy is a repo-first orchestration layer for long-running coding and research
          projects. Plan, execute, review, reconcile, and report across Trae, CLI, and team
          workflows.
        </p>
        <div class="hero-actions">
          <a class="button" href={`${baseUrl}docs/quickstart/`}>Read Quickstart</a>
          <a class="button-secondary" href={`${baseUrl}how-it-works/`}>How It Works</a>
        </div>
      </div>
      <aside class="hero-card">
        <p class="mini-title">What It Is</p>
        <ul>
          <li>A campaign system for multi-stage AI coding and research</li>
          <li>Explicit roles: planner, reviewer, executor</li>
          <li>Reconcile-driven state instead of chat memory drift</li>
          <li>Built for code, experiments, metrics, and reports</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Differentiation</p>
      <h2>Not another disposable agent.</h2>
      <p class="section-copy">
        Most autonomous agents are optimized for a single task. CodeArmy is built for campaigns:
        multi-stage efforts that span planning, implementation, experimentation, review, and final
        reporting.
      </p>
      <div class="grid-3">
        {pillars.map((pillar) => (
          <article class="card">
            <h3>{pillar.title}</h3>
            <p>{pillar.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <div>
        <p class="eyebrow">Workflow</p>
        <h2>From campaign setup to closure report.</h2>
        <p class="section-copy">
          CodeArmy organizes AI coding work as a closed loop, so every round of planning,
          execution, and review leaves durable structure in the repo.
        </p>
        <div class="workflow">
          {workflow.map((step, idx) => (
            <div class="workflow-step">
              <strong>{idx + 1}</strong>
              <p>{step}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="panel" style="padding: 1.5rem;">
        <p class="mini-title">Integrations</p>
        <ul class="feature-list">
          {integrations.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Research Use Cases</p>
      <h2>Used in real research workflows.</h2>
      <p class="section-copy">
        CodeArmy is especially well suited to long-running research workflows where code changes,
        experiment runs, metrics, cluster jobs, and reports all need to move together.
      </p>
      <div class="grid-2">
        <article class="card">
          <h3>JUNO Monte Carlo parameter tuning</h3>
          <p>
            Treat Monte Carlo parameter optimization as a campaign with hypotheses, scheduled runs,
            metrics, reviews, and evidence-backed summaries.
          </p>
        </article>
        <article class="card">
          <h3>CEPC fast-simulation DiT optimization</h3>
          <p>
            Manage model architecture changes, training runs, speed-quality tradeoffs, and
            evaluation results with a single repo-first workflow.
          </p>
        </article>
      </div>
      <div class="hero-actions" style="margin-top: 1.5rem;">
        <a class="button-secondary" href={`${baseUrl}research-use-cases/`}>
          Explore Research Use Cases
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Entry Points</p>
      <h2>One core, multiple surfaces.</h2>
      <p class="section-copy">
        CodeArmy is designed so the same campaign state can be used from Trae Solo, local CLI,
        collaboration channels, and remote execution environments.
      </p>
      <div class="grid-2">
        {entryPoints.map((ep) => (
          <article class="card">
            <h3>{ep.title}</h3>
            <p>{ep.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container callout">
      <strong>Start with the basics</strong>
      The first public release should be a focused product for long-running AI coding and research
      campaigns, not another general-purpose chat agent.
      <div class="hero-actions" style="margin-top: 1rem;">
        <a class="button" href={`${baseUrl}docs/quickstart/`}>Open Quickstart</a>
        <a class="button-secondary" href={`${baseUrl}research-use-cases/`}>
          Explore Research Use Cases
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
