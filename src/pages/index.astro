---
import BaseLayout from "../layouts/BaseLayout.astro";

const pillars = [
  {
    title: "Repo-First Campaigns",
    text: "Track long-horizon work in a structured campaign, not a disposable chat thread."
  },
  {
    title: "Hard Workflow Gates",
    text: "Plan, review, approve, execute, reconcile, and report with explicit transitions."
  },
  {
    title: "Research-Ready",
    text: "Designed for code, experiments, cluster runs, metrics, and evidence to move together."
  }
];

const integrations = ["Trae Solo", "CLI", "Feishu", "Cluster / HPC", "Reports", "Repo Templates"];
---

<BaseLayout
  title="Repo-First Orchestration for Long-Horizon AI Coding"
  description="CodeArmy turns long-running coding and research efforts into structured campaigns with planning, review, reconcile, and reporting."
>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">CodeArmy</p>
        <h1>Turn long-horizon AI coding into structured campaigns.</h1>
        <p class="lead">
          CodeArmy is a repo-first orchestration layer for long-running coding and research
          projects. Plan, execute, review, reconcile, and report across Trae, CLI, and team
          workflows.
        </p>
        <div class="hero-actions">
          <a class="button" href={`${import.meta.env.BASE_URL}docs/quickstart/`}>Read Quickstart</a>
          <a class="button-secondary" href={`${import.meta.env.BASE_URL}how-it-works/`}>
            How It Works
          </a>
        </div>
      </div>
      <aside class="hero-card">
        <p class="mini-title">Not Another Disposable Agent</p>
        <ul>
          <li>Campaigns instead of one-off prompts</li>
          <li>Planner, reviewer, and executor role discipline</li>
          <li>Reconcile-driven state instead of chat memory drift</li>
          <li>Designed for coding plus experiments, metrics, and reports</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Why CodeArmy</p>
      <h2>Built for work that lasts longer than a single prompt.</h2>
      <p class="section-copy">
        Most autonomous agents are optimized for a single task. CodeArmy is built for campaigns:
        multi-stage efforts that span planning, implementation, experimentation, review, and final
        reporting.
      </p>
      <div class="grid-3">
        {pillars.map((pillar) => (
          <article class="card">
            <h3>{pillar.title}</h3>
            <p>{pillar.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <div>
        <p class="eyebrow">Workflow</p>
        <h2>From campaign setup to closure report.</h2>
        <p class="section-copy">
          CodeArmy organizes AI coding work as a closed loop, so every round of planning,
          execution, and review leaves durable structure in the repo.
        </p>
        <div class="workflow">
          <div class="workflow-step">
            <strong>1</strong>
            <p>Create a campaign with a clear objective, baseline, and gates.</p>
          </div>
          <div class="workflow-step">
            <strong>2</strong>
            <p>Generate task packages that give each role a bounded, auditable unit of work.</p>
          </div>
          <div class="workflow-step">
            <strong>3</strong>
            <p>Run planner, reviewer, and executor loops with explicit handoff states.</p>
          </div>
          <div class="workflow-step">
            <strong>4</strong>
            <p>Reconcile the repo to refresh live status, select next actions, and surface blockers.</p>
          </div>
          <div class="workflow-step">
            <strong>5</strong>
            <p>Publish progress and closure reports without losing the evidence trail.</p>
          </div>
        </div>
      </div>
      <div class="panel" style="padding: 1.5rem;">
        <p class="mini-title">Integrations</p>
        <ul class="feature-list">
          {integrations.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
        <div class="callout" style="margin-top: 1.2rem;">
          <strong>Current wedge</strong>
          Used in real research workflows, including JUNO Monte Carlo parameter tuning and CEPC
          fast-simulation DiT optimization.
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Entry Points</p>
      <h2>One core, multiple surfaces.</h2>
      <p class="section-copy">
        CodeArmy is designed so the same campaign state can be used from Trae Solo, local CLI,
        collaboration channels, and remote execution environments.
      </p>
      <div class="grid-2">
        <article class="card">
          <h3>Trae Solo</h3>
          <p>
            Use CodeArmy as the orchestration layer behind custom agents, MCP tools, and Skills.
          </p>
        </article>
        <article class="card">
          <h3>CLI and Automation</h3>
          <p>
            Create campaigns, reconcile state, and generate reports from scripts and scheduled jobs.
          </p>
        </article>
        <article class="card">
          <h3>Feishu and Team Sync</h3>
          <p>
            Push summaries, approvals, and report artifacts back into team collaboration channels.
          </p>
        </article>
        <article class="card">
          <h3>Cluster Workflows</h3>
          <p>
            Connect experiments, training runs, and evaluation jobs to the same campaign timeline.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container callout">
      <strong>Start with the basics</strong>
      The first public release should be a focused product for long-running AI coding and research
      campaigns, not another general-purpose chat agent.
      <div class="hero-actions" style="margin-top: 1rem;">
        <a class="button" href={`${import.meta.env.BASE_URL}docs/quickstart/`}>Open Quickstart</a>
        <a class="button-secondary" href={`${import.meta.env.BASE_URL}research-use-cases/`}>
          Explore Research Use Cases
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
