---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pillars = [
  {
    title: "以仓库为中心的战役",
    text: "在结构化的战役中跟踪长期工作，而非一次性的对话线程。"
  },
  {
    title: "严格的工作流关卡",
    text: "计划、审核、批准、执行、对账和报告，每个阶段都有明确的转换。"
  },
  {
    title: "研究就绪",
    text: "为代码、实验、集群运行、指标和证据协同移动而设计。"
  }
];

const integrations = ["Trae Solo", "CLI", "飞书", "集群 / HPC", "报告", "仓库模板"];
---

<BaseLayout
  title="面向长期 AI 编程的仓库优先编排"
  description="CodeArmy 将长期编程和研究工作转化为结构化战役，包含计划、审核、对账和报告。"
>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">CodeArmy</p>
        <h1>将长期 AI 编程转化为结构化战役。</h1>
        <p class="lead">
          CodeArmy 是一个面向长期编程和研究项目的仓库优先编排层。
          在 Trae、CLI 和团队工作流中进行计划、执行、审核、对账和报告。
        </p>
        <div class="hero-actions">
          <a class="button" href={`${import.meta.env.BASE_URL}docs/quickstart/`}>阅读快速开始</a>
          <a class="button-secondary" href={`${import.meta.env.BASE_URL}how-it-works/`}>
            工作原理
          </a>
        </div>
      </div>
      <aside class="hero-card">
        <p class="mini-title">不是又一个一次性智能体</p>
        <ul>
          <li>战役而非一次性提示</li>
          <li>规划者、审核者和执行者的角色纪律</li>
          <li>对账驱动的状态而非对话记忆漂移</li>
          <li>为编程、实验、指标和报告而设计</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">为何选择 CodeArmy</p>
      <h2>为持续超过单个提示的工作而构建。</h2>
      <p class="section-copy">
        大多数自主智能体都针对单一任务进行了优化。CodeArmy 为战役而生：
        跨越规划、实施、实验、审核和最终报告的多阶段工作。
      </p>
      <div class="grid-3">
        {pillars.map((pillar) => (
          <article class="card">
            <h3>{pillar.title}</h3>
            <p>{pillar.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <div>
        <p class="eyebrow">工作流</p>
        <h2>从战役设置到结案报告。</h2>
        <p class="section-copy">
          CodeArmy 将 AI 编码工作组织为一个闭环，因此每一轮规划、
          执行和审核都会在仓库中留下持久的结构。
        </p>
        <div class="workflow">
          <div class="workflow-step">
            <strong>1</strong>
            <p>创建具有明确目标、基线和关卡的战役。</p>
          </div>
          <div class="workflow-step">
            <strong>2</strong>
            <p>生成任务包，为每个角色提供有界的、可审计的工作单元。</p>
          </div>
          <div class="workflow-step">
            <strong>3</strong>
            <p>运行规划者、审核者和执行者循环，并明确交接状态。</p>
          </div>
          <div class="workflow-step">
            <strong>4</strong>
            <p>对账仓库以刷新实时状态、选择下一步行动并暴露阻塞项。</p>
          </div>
          <div class="workflow-step">
            <strong>5</strong>
            <p>发布进度和结案报告，而不会丢失证据线索。</p>
          </div>
        </div>
      </div>
      <div class="panel" style="padding: 1.5rem;">
        <p class="mini-title">集成</p>
        <ul class="feature-list">
          {integrations.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
        <div class="callout" style="margin-top: 1.2rem;">
          <strong>当前切入</strong>
          用于真实的研究工作流，包括 JUNO 蒙特卡洛参数调优和 CEPC
          快速模拟 DiT 优化。
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">入口点</p>
      <h2>一个核心，多种界面。</h2>
      <p class="section-copy">
        CodeArmy 的设计使得相同的战役状态可以从 Trae Solo、本地 CLI、
        协作渠道和远程执行环境中使用。
      </p>
      <div class="grid-2">
        <article class="card">
          <h3>Trae Solo</h3>
          <p>
            将 CodeArmy 用作自定义智能体、MCP 工具和技能背后的编排层。
          </p>
        </article>
        <article class="card">
          <h3>CLI 和自动化</h3>
          <p>
            从脚本和定时任务创建战役、对账状态和生成报告。
          </p>
        </article>
        <article class="card">
          <h3>飞书和团队同步</h3>
          <p>
            将摘要、批准和报告工件推送回团队协作渠道。
          </p>
        </article>
        <article class="card">
          <h3>集群工作流</h3>
          <p>
            将实验、训练运行和评估作业连接到同一个战役时间线。
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container callout">
      <strong>从基础开始</strong>
      第一个公开发布应该是面向长期 AI 编码和研究战役的专注产品，
      而非另一个通用聊天智能体。
      <div class="hero-actions" style="margin-top: 1rem;">
        <a class="button" href={`${import.meta.env.BASE_URL}docs/quickstart/`}>打开快速开始</a>
        <a class="button-secondary" href={`${import.meta.env.BASE_URL}research-use-cases/`}>
          探索研究用例
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
