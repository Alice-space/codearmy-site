---
import BaseLayout from "../../layouts/BaseLayout.astro";

const redirectTo = `${import.meta.env.BASE_URL}zh/#workflow`;
---

<BaseLayout
  title="工作原理"
  description="本页已并入单页，自动跳转到工作原理区块。"
>
  <section class="container page-hero redirect-note">
    <p class="eyebrow">跳转中</p>
    <h1>工作原理已并入单页官网。</h1>
    <p class="lead">
      页面已跳转至<a href={redirectTo}>工作原理区块</a>，请继续查看。
    </p>
    <a class="button" href={redirectTo}>前往区块</a>
  </section>
</BaseLayout>

<script is:inline>
  window.location.replace("{redirectTo}");
</script>
