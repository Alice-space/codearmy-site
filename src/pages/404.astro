---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteContent } from "../lib/site-content";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const addBase = (path: string) => {
  if (baseUrl === "/") return path;
  return `${baseUrl.replace(/\/$/, "")}${path}`;
};

const englishHome = addBase("/");
const chineseHome = addBase("/zh/");
const englishFlow = `${englishHome}#flow`;
const chineseCases = `${chineseHome}#cases`;
const content = siteContent.en;
---

<BaseLayout
  locale="en"
  title="Page not found"
  description="Return to the current CodeArmy single-page site in English or Chinese."
  navItems={content.navItems}
  footerNote={content.footer.note}
>
  <section class="section-block">
    <div class="container not-found-shell">
      <p class="eyebrow">404</p>
      <h1>That page no longer exists as a standalone route.</h1>
      <p class="lead">
        CodeArmy now uses one English page and one Chinese page. If you opened an old route,
        jump back to the current single-page entry.
      </p>
      <div class="hero-actions">
        <a class="button" href={englishHome}>English Home</a>
        <a class="button-secondary" href={englishFlow}>English Workflow</a>
        <a class="button-secondary" href={chineseHome}>中文首页</a>
        <a class="button-secondary" href={chineseCases}>中文案例</a>
      </div>
      <div class="not-found-grid">
        <article class="case-card">
          <span class="case-status">English</span>
          <h2>Use the single-page entry</h2>
          <p>
            The current site is organized as anchors on the homepage: architecture, workflow,
            capabilities, cases, roadmap, and quickstart.
          </p>
        </article>
        <article class="case-card">
          <span class="case-status">中文</span>
          <h2>请回到单页入口</h2>
          <p>
            现在站点统一收敛为单页结构，包含架构、流程图、能力、案例、路线图和快速入门几个区块。
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
