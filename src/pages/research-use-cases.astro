---
import BaseLayout from "../layouts/BaseLayout.astro";

const redirectTo = `${import.meta.env.BASE_URL}#cases`;
---

<BaseLayout
  title="Research Use Cases"
  description="This page now redirects to the one-page research section."
>
  <section class="container page-hero redirect-note">
    <p class="eyebrow">Redirecting</p>
    <h1>Research Use Cases has moved into the one-page homepage.</h1>
    <p class="lead">
      You are being redirected to <a href={redirectTo}>the research section</a>.
    </p>
    <a class="button" href={redirectTo}>Go to Research Use Cases</a>
  </section>
</BaseLayout>

<script is:inline>
  window.location.replace("{redirectTo}");
</script>
