---
import BaseLayout from "../layouts/BaseLayout.astro";

const redirectTo = `${import.meta.env.BASE_URL}#workflow`;
---

<BaseLayout
  title="How It Works"
  description="This page now redirects to the single-page workflow section."
>
  <section class="container page-hero redirect-note">
    <p class="eyebrow">Redirecting</p>
    <h1>How It Works has moved to the one-page homepage.</h1>
    <p class="lead">
      You are being redirected to <a href={redirectTo}>the workflow section</a>.
    </p>
    <a class="button" href={redirectTo}>Go to Workflow</a>
  </section>
</BaseLayout>

<script is:inline>
  window.location.replace("{redirectTo}");
</script>
