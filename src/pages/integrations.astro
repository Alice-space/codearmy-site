---
import BaseLayout from "../layouts/BaseLayout.astro";

const redirectTo = `${import.meta.env.BASE_URL}#entry`;
---

<BaseLayout
  title="Integrations"
  description="This page now redirects to the one-page entry surfaces section."
>
  <section class="container page-hero redirect-note">
    <p class="eyebrow">Redirecting</p>
    <h1>Integrations has moved into the one-page homepage.</h1>
    <p class="lead">
      You are being redirected to <a href={redirectTo}>the entry surfaces section</a>.
    </p>
    <a class="button" href={redirectTo}>Go to Entry Surfaces</a>
  </section>
</BaseLayout>

<script is:inline>
  window.location.replace("{redirectTo}");
</script>
