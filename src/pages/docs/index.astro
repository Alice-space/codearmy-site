---
import BaseLayout from "../../layouts/BaseLayout.astro";

const redirectTo = `${import.meta.env.BASE_URL}#docs`;
---

<BaseLayout
  title="Docs"
  description="This page now redirects to the one-page docs section."
>
  <section class="container page-hero redirect-note">
    <p class="eyebrow">Redirecting</p>
    <h1>Docs index has moved to the one-page homepage.</h1>
    <p class="lead">
      You are being redirected to <a href={redirectTo}>the Quickstart section</a>.
    </p>
    <a class="button" href={redirectTo}>Go to Docs</a>
  </section>
</BaseLayout>

<script is:inline>
  window.location.replace("{redirectTo}");
</script>
